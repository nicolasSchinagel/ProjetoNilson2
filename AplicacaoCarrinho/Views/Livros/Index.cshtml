@model AplicacaoCarrinho.Models.Livro

@{
    ViewData["Title"] = "Cadastrar Novo Livro";
}
<h2 style="text-align:center;">Novo Livro</h2>

<div class="center">
    @using(Html.BeginForm("Index","Livros", FormMethod.Post, new{enctype="multipart/form-data"}))
    {
        @Html.AntiForgeryToken()

        <div class="form-horizontal">
            <hr />
            @Html.ValidationSummary(true, "", new { @class = "text-danger"})
            <div class="form-group space-around-flex">
                <div class="">
                    @Html.LabelFor(model => model.NomeLivro, htmlAttributes: new { @class = "control-label col-md-2" })
                </div>
                <div class="col-md-10">
                    @Html.EditorFor(model => model.NomeLivro, new {htmlAttributes = new{@class = "form-control"}})
                    @Html.ValidationMessageFor(model => model.NomeLivro, "", new{@class = "text-danger"})
                </div>
            </div>
            <!--Parei aqui hoje-->
        </div>
    }

</div>